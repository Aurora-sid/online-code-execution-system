# 在线代码执行系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
# MySQL 连接配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=13306
MYSQL_USER=codeexec
MYSQL_PASSWORD=codeexec123
MYSQL_DATABASE=code_exec

# ==================== Redis 配置 ====================
REDIS_ADDR=127.0.0.1:16379

# ==================== JWT 配置 ====================
# 重要：生产环境必须设置强密钥！
# 推荐使用 openssl rand -hex 32 生成
JWT_SECRET=5f8d3c2b1a4e6d7f9a8b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f

# ==================== 服务器配置 ====================
SERVER_PORT=:8080

# ==================== CORS 配置 ====================
# 多个源用逗号分隔
# 使用 * 允许所有来源（开发/测试环境）
# 生产环境建议指定具体 IP，例如 http://192.168.1.100:5173
ALLOWED_ORIGINS=*  // 允许所有来源，开发环境使用，生产环境请修改为具体 IP 或域名

# ==================== 容器池配置 ====================
# 每种语言的最大容器缓存数（向后兼容，实际由 HWM 控制）
CONTAINER_POOL_SIZE=3
# 容器内存限制 (MB)
CONTAINER_MEMORY_MB=2048
# 容器 CPU 核心数
CONTAINER_CPU_CORES=2.0

# ==================== 弹性容器调度配置 ====================
# 低水位线：每种语言最少保持的闲置容器数（低于此值触发自动预热）
CONTAINER_LWM=2
# 高水位线：每种语言最多缓存的闲置容器数（超过此值归还时销毁）
CONTAINER_HWM=8
# 监控协程检查间隔（秒），控制系统检查容器水位的频率，过短会增加系统负担，过长会导致响应变慢
MONITOR_INTERVAL=3

# ==================== 弹性调度 - 动态水位参数 ====================
# EMAAlpha: 0.3 表示当前请求率占 30%，历史请求率占 70%，适度平滑波动，快速响应负载变化
EMA_ALPHA=0.3
# LWMMin: 动态下限的最小值，确保系统在低负载时也能保持一定的预热容器，避免冷启动
LWM_MIN=1
# LWMMax: 动态下限的最大值，限制系统在高负载时预热过多容器，防止资源过度消耗
LWM_MAX=20

# ==================== 数据库连接池配置 ====================
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100

# ==================== 管理员账号配置 ====================
# 默认管理员用户名
ADMIN_USERNAME=admin
# 默认管理员密码 (生产环境请修改!)
ADMIN_PASSWORD=admin123

# ==================== LLM 配置 (智谱 AI / ChatGLM) ====================
# API 提供商 (zhipu)
LLM_PROVIDER=zhipu
# API 密钥 (从 open.bigmodel.cn 获取)
LLM_API_KEY=e7933e0b37fa41338cf3762c5743e0f2.dF1lrQmALSqWXJn6
# API 地址
LLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
# 模型名称 (codegeex-4 免费，代码专用)
LLM_MODEL=codegeex-4   # 默认模型，支持 codegeex-4，可以由管理员动态调整

